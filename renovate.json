{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":ignoreModulesAndTests",
    "group:monorepos",
    "mergeConfidence:age-confidence-badges",
    "replacements:all",
    "workarounds:all"
  ],
  "gitIgnoredAuthors": ["github-actions[bot]@users.noreply.github.com"],
  "timezone": "UTC",
  "schedule": ["at any time"],
  "labels": ["dependencies"],
  "assignees": ["ndrwstn"],
  "commitMessagePrefix": "update",
  "commitMessageTopic": "{{ lookup (split depName '/') 1 }}",
  "commitMessageExtra": "-> {{newVersion}}",
  "branchPrefix": "update/",
  "branchTopic": "{{depNameSanitized}}-{{newVersion}}",
  "fetchChangeLogs": "pr",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update GCS version in packages/gcs/default.nix",
      "managerFilePatterns": ["/^packages/gcs/default\\.nix$/"],
      "matchStrings": ["version = \"(?<currentValue>.*?)\";"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "richardwilkes/gcs",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update opencode version in flake.nix",
      "managerFilePatterns": ["/^flake\\.nix$/"],
      "matchStrings": [
        "opencode\\.url = \"github:anomalyco/opencode/v(?<currentValue>.*?)\";"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "anomalyco/opencode",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update agent-browser version in packages/agent-browser/default.nix",
      "managerFilePatterns": ["/^packages/agent-browser/default\\.nix$/"],
      "matchStrings": ["version = \"(?<currentValue>.*?)\";"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "vercel-labs/agent-browser",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update ocrit version in packages/ocrit/default.nix",
      "managerFilePatterns": ["/^packages/ocrit/default\\.nix$/"],
      "matchStrings": ["version = \"(?<currentValue>.*?)\";"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "insidegui/ocrit",
      "extractVersionTemplate": "^(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update pinned nixpkgs rev",
      "managerFilePatterns": ["/^flake\\.nix$/"],
      "matchStrings": [
        "nixpkgs\\.url = \"github:NixOS/nixpkgs/(?<currentValue>[a-f0-9]{40})\""
      ],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "NixOS/nixpkgs",
      "currentValueTemplate": "nixpkgs-unstable"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["anomalyco/opencode"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchPackageNames": ["vercel-labs/agent-browser"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "matchDepNames": ["NixOS/nixpkgs"],
      "branchTopic": "nixpkgs",
      "schedule": ["after 4am and before 5am on saturday"],
      "timezone": "UTC"
    }
  ]
}
